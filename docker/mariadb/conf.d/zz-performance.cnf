[mysqld]
skip-name-resolve

# InnoDB sizing tuned for a small-to-medium WordPress workload.
innodb_buffer_pool_size = 1G
innodb_log_file_size = 256M
innodb_log_buffer_size = 32M
innodb_flush_method = O_DIRECT
innodb_flush_log_at_trx_commit = 2

# Keep temporary tables in memory more often.
tmp_table_size = 64M
max_heap_table_size = 64M

# Avoid undersized defaults for common WordPress/plugin query patterns.
table_open_cache = 4096
table_definition_cache = 2048
thread_cache_size = 100

# Conservative per-connection buffers to prevent memory spikes.
sort_buffer_size = 2M
join_buffer_size = 2M
read_buffer_size = 256K
read_rnd_buffer_size = 512K

# Observe and diagnose slow queries.
slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time = 1
log_queries_not_using_indexes = 1
log_slow_verbosity = query_plan,innodb

# Keep idle connections from hanging around forever.
wait_timeout = 120
interactive_timeout = 120
